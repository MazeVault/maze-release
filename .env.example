# ─────────────────────────────────────────────────────────────────────────────
# MazeVault — Environment Configuration Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy to .env and fill in all __PLACEHOLDER__ values before starting.
#
# SECURITY: This file contains secrets — set permissions: chmod 600 .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Image Registry ──────────────────────────────────────────────────────────
# For GHCR (default):  ghcr.io/mazevault
# For private registry: registry.corp.com/mazevault
# For offline/local:    ghcr.io/mazevault (images loaded from tarball)
IMAGE_REGISTRY=ghcr.io/mazevault
IMAGE_TAG=latest

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=mazevault
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
POSTGRES_DB=mazevault
# Optional: use a custom image for air-gapped (e.g., registry.corp.com/postgres:15-alpine)
# POSTGRES_IMAGE=postgres:15-alpine

# ── Redis ───────────────────────────────────────────────────────────────────
REDIS_PASSWORD=__REDIS_PASSWORD__
REDIS_MAX_MEMORY=256mb
# REDIS_IMAGE=redis:7-alpine

# ── Application Secrets ─────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48 | tr -d '\n/+='
JWT_SECRET=__JWT_SECRET__
MASTER_KEY=__MASTER_KEY__
SESSION_SECRET=__SESSION_SECRET__

# ── TLS / HTTPS ─────────────────────────────────────────────────────────────
# Set to true to skip certificate generation (e.g., if behind a load balancer)
MAZEVAULT_TLS_SKIP_INIT=false

# Domain name for self-signed certificate SANs
MAZEVAULT_DOMAIN=localhost

# Path to directory with custom certs (server.crt + server.key)
# If these files exist, init-certs will use them instead of generating self-signed
# CUSTOM_CERT_DIR=./certs

# ── Port Mapping ────────────────────────────────────────────────────────────
FRONTEND_PORT=443
FRONTEND_HTTP_PORT=80
BACKEND_PORT=8443
DOCS_PORT=8088
DOCS_URL=https://localhost:8088

# ── License Registration ────────────────────────────────────────────────────
# Required for license activation, compliance reporting, and certificate notifications
MAZEVAULT_CUSTOMER_NAME=__CUSTOMER_NAME__
MAZEVAULT_CUSTOMER_EMAIL=__CUSTOMER_EMAIL__
MAZEVAULT_COMPANY_ID=__COMPANY_ID__
# Optional: unique instance identifier (auto-generated if not set)
MAZEVAULT_INSTANCE_ID=
# Optional: geographic region for license compliance (default: EU)
# Options: EU, US, APAC
MAZEVAULT_REGION=EU

# ── Application ─────────────────────────────────────────────────────────────
MAZEVAULT_ENV=production
MAZEVAULT_ORCHESTRATOR_MODE=false
LOG_LEVEL=info
ALLOWED_ORIGINS=https://localhost
CORS_ALLOWED_ORIGINS=https://localhost

# Cookie security — set to true for HTTPS on real domains, false for localhost
COOKIE_SECURE=true

# Swagger UI (enabled by default, set to false to disable in hardened environments)
SWAGGER_ENABLED=true

# ── SMTP / Email Notifications ──────────────────────────────────────────────
# Required for email notifications (certificate expiry, incident alerts)
# Leave empty to disable email notifications
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ── Office365 OAuth2 Email (optional — takes priority over SMTP) ────────────
# Enable Office365 email sending via Microsoft Graph API (OAuth2)
# Requires Azure AD App Registration with Mail.Send application permission
# When enabled, SMTP settings above are ignored for email sending
# O365_EMAIL_ENABLED=true
# O365_TENANT_ID=                        # Azure AD tenant ID
# O365_CLIENT_ID=                        # App registration client ID with Mail.Send
# O365_CLIENT_SECRET=                    # Client secret (for client_secret auth)
# O365_SENDER_EMAIL=                     # Sender email (user or shared mailbox)
# O365_AUTH_METHOD=client_secret         # client_secret | certificate | managed_identity
# O365_CERTIFICATE_PATH=                 # Path to PFX/PEM cert (for certificate auth)
# O365_CERTIFICATE_PASSWORD=             # Certificate password (for certificate auth)
# O365_MANAGED_IDENTITY_CLIENT_ID=       # MI client ID (for managed_identity auth in Azure)
# Frontend URL — used for CORS and redirects
FRONTEND_URL=https://localhost

# ── OCSP Responder ──────────────────────────────────────────────────────────
# Internal URL for OCSP health checks (Docker service name)
# Default: http://ocsp:8081 — matches the 'ocsp' service in docker-compose
OCSP_URL=http://ocsp:8081

# ── Entra ID / SSO (optional — enable for Azure AD login) ──────────────────
# Register an app in Azure Portal → App registrations → set redirect URI
# ENTRA_CLIENT_ID=
# ENTRA_CLIENT_SECRET=
# ENTRA_TENANT_ID=
# ENTRA_REDIRECT_URI=       # Optional: auto-derived from FRONTEND_URL if empty
# MAZEVAULT_ENFORCE_OIDC_NONCE=false  # Reject tokens with nonce mismatch (default: warn only)

# ── Azure AD Token Validation (optional) ────────────────────────────────────
# AZURE_AD_TENANT_ID=       # Tenant for JWT issuer validation
# AZURE_AD_ALLOWED_TENANTS= # Comma-separated allowed tenant IDs (multi-tenant)
# AZURE_AD_JWKS_CACHE_TTL=86400   # JWKS cache in seconds (default: 24h)

# ── Azure Managed Identity (optional — for Azure Key Vault access) ──────────
# AZURE_MANAGED_IDENTITY_CLIENT_ID=  # User-assigned MI client ID
# AZURE_TENANT_ID=                    # Azure tenant for MI credential factory
# AZURE_DEPLOYMENT=false              # Enable Azure-specific features

# ── Resource Limits (optional) ──────────────────────────────────────────────
# BACKEND_MEMORY_LIMIT=1g
# FRONTEND_MEMORY_LIMIT=256m

# ── Agent Binary Proxy (optional — for private release repo) ───────────────
# AGENT_BINARY_GITHUB_TOKEN=       # PAT with read access to MazeVault/maze-release
# AGENT_BINARY_CACHE_DIR=/data/agent-binaries  # Disk cache for downloaded binaries
# AGENT_BINARY_RELEASE_API_URL=    # GitHub Releases API URL (default: auto-detected)
# AGENT_ROLLOUT_PERCENTAGE=100     # 0-100, percentage of agents that see updates
# AGENT_MAX_CONCURRENT_DOWNLOADS=10  # Max concurrent binary download streams
# AGENT_DOWNLOAD_BASE_URL=         # Base URL for agent binary downloads (default: GitHub Releases)
# AGENT_VERSION=latest             # Agent version to download (latest or vX.Y.Z)

# ── Gateway Mode (optional — for multi-DC satellite instances) ──────────────
# Set MAZEVAULT_MODE=gateway to run as a satellite syncing with a primary instance.
# When running as primary (default), these variables are ignored.
# MAZEVAULT_MODE=primary                 # primary | gateway
# PRIMARY_BACKEND_URL=                   # URL of the primary instance (gateway mode only)
# GATEWAY_BOOTSTRAP_TOKEN=               # One-time token from primary (gateway mode only)
# GATEWAY_NAME=                          # Unique gateway name (e.g., gateway-dc2)
# MAZEVAULT_GATEWAY_ENVIRONMENT=NPR      # NPR | PRO (single-env, backward compat)
# MAZEVAULT_GATEWAY_ENVIRONMENTS=ITG,TST,PRE  # Multi-env: comma-separated (takes priority over singular)
# MAZEVAULT_GATEWAY_ROLE=primary         # primary | dr-standby
# MAZEVAULT_GATEWAY_STATE_FILE=/etc/mazevault/gateway-state.json  # Path to gateway state file
# MAZEVAULT_VERSION=latest               # Software version tag
# MAZEVAULT_PRIMARY_ENVIRONMENTS=         # Comma-separated envs for primary backend (seeds on first startup)

# ── Agent Trust Store (optional — controls CA chain installation to OS trust stores) ──
# MAZEVAULT_AGENT_INSTALL_CHAIN_TO_TRUSTSTORE=true  # Install CA/CAi to OS trust stores (default: true)
# MAZEVAULT_AGENT_TRUST_STORE_PATH=                 # Override Linux trust dir (auto-detected by default)

# ── ACME DNS-01 (optional — for wildcard certificate validation) ──
# MAZEVAULT_ACME_DNS_PROVIDER=none        # DNS provider for ACME DNS-01 challenges (cloudflare/none)
# MAZEVAULT_ACME_DNS_API_TOKEN=           # API token for DNS provider (encrypted at rest)

# ── KeyTab Management (optional — Kerberos keytab lifecycle) ──
# MAZEVAULT_KEYTAB_ENABLED=true           # Enable keytab management module (default: true)
# MAZEVAULT_KEYTAB_MAX_SIZE_MB=10         # Max keytab file size in MB (default: 10)
# MAZEVAULT_KEYTAB_DEFAULT_EXPIRY_DAYS=365 # Default keytab expiry in days (default: 365)
